@page "/JsToReferenceNetDemo"
@implements IDisposable

<h3>JsToReferenceNet</h3>

<button class="btn btn-success" @onclick="TriggerDotNetInstanceMethod">Click me (instance method)</button>


<button class="btn btn-success" onclick="callnetfromjs()">Click me (static method)</button>


<span style="">@result</span>

<span id="StaticResultId" style="font-family: 'Comic Sans MS',Verdana, Geneva, Tahoma, sans-serif"</span>

@code {


    private DotNetObjectReference<JsToReferenceNet>? dotNetHelper;

    [Inject] IJSRuntime js { get; set; } = default!;

    IJSObjectReference jsModule = default!;

    private string? result;

    protected async override Task OnInitializedAsync()
    {
        jsModule = await js.InvokeAsync<IJSObjectReference>("import", "/Components/Demos/Javascript/Components/JsToReferenceNet.razor.js");
        dotNetHelper = DotNetObjectReference.Create(this);
    }

    public async Task TriggerDotNetInstanceMethod()
    {
        result = await jsModule.InvokeAsync<string>("callreferencenetfromjs", dotNetHelper);
        StateHasChanged();
    }

    [JSInvokable]
    public string GetHelloMessage(string name) => $"Hello, {name} it {DateTime.Now.ToString("HH:mm:ss")}";

    [JSInvokable("NameOfTheMethod")]
    public static Task<string> GetAMessageFromNet()
    {
        return Task.FromResult($"<br />This is message from .NET {DateTime.Now.ToString("HH:mm:ss")}<br />");
    }

    public void Dispose()
    {
        dotNetHelper?.Dispose();
    }

}
