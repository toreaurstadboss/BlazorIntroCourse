{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "kill-process",
            "command": "powershell",
            "type": "shell",
            "args": [
                "-Command",
                "Get-Process -Name dotnet -ErrorAction SilentlyContinue | Stop-Process -Force"
            ],
            "isBackground": false,
            "presentation": {
                "reveal": "silent"
            }
        },
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/DependencyInjectionDemo.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "clean",
            "command": "dotnet",
            "type": "process",
            "args": [
                "clean",
                "${workspaceFolder}/DependencyInjectionDemo.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "rebuild",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/DependencyInjectionDemo.csproj",
                "--configuration",
                "Debug",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "build"
            }
        },
        {
            "label": "watch",
            "command": "dotnet",
            "type": "shell",
            "args": [
                "watch",
                "--project",
                "${workspaceFolder}/DependencyInjectionDemo.csproj",
                "run"
            ],
            "isBackground": true,
            "problemMatcher": {
                "pattern": "$msCompile",
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^dotnet watch",
                    "endsPattern": "^Now listening on:"
                }
            }
        }
    ]
}
